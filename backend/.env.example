# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ayu_db

# Security - REQUIRED: Generate a strong key before running!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Stripe Payment Keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Gemini Image API (Google AI Studio) - optional paid API provider
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Local enhancement providers
# FACE_RESTORE_PROVIDER: vqfr | codeformer | gemini
# UPSCALE_PROVIDER: pisasr | realesrgan | gemini
FACE_RESTORE_PROVIDER=vqfr
UPSCALE_PROVIDER=pisasr
LOCAL_ENHANCE_ALLOW_FALLBACK=true
VQFR_REPO_DIR=external_repos/VQFR
VQFR_MODEL_VERSION=1.0
VQFR_MODEL_PATH=external_repos/VQFR/experiments/pretrained_models/VQFR_v1-33a1fac5.pth
VQFR_FIDELITY_RATIO=0.0
VQFR_UPSCALE=2
PISASR_REPO_DIR=external_repos/PiSA-SR
PISASR_PYTHON=external_repos/PiSA-SR/.venv/Scripts/python.exe
PISASR_SD21_PATH=external_repos/PiSA-SR/preset/models/stable-diffusion-2-1-base
PISASR_MODEL_PATH=external_repos/PiSA-SR/preset/models/pisa_sr.pkl
PISASR_PROCESS_SIZE=512
PISASR_UPSCALE=4

# Admin User (used by init_db.py for initial setup)
ADMIN_EMAIL=admin@ayu.kz
ADMIN_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
