# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ayu_db

# Security - REQUIRED: Generate a strong key before running!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Stripe Payment Keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin User (used by init_db.py for initial setup)
ADMIN_EMAIL=admin@ayu.kz
ADMIN_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
